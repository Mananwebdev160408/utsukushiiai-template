{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": true,
    "baseUrl": "../src",
    "paths": {
      "@/*": ["./*"]
    },
    "types": ["node", "jest"],
    "rootDir": "../",
    "noEmit": true
  },
  "include": ["**/*", "../src/**/*"],
  "exclude": []
}
